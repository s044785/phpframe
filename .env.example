APP_ENV=dev
APP_URL=http://localhost:8080

DB_DSN="mysql:host=127.0.0.1;port=3306;dbname=phpframe;charset=utf8mb4"
DB_USER=root
DB_PASS=root

# Redis（可选，默认 127.0.0.1:6379 无密码）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0

# 邮件（配置 SMTP 后优先使用；未配置则用系统 mail() + 日志兜底）
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@phpframe.local
MAIL_FROM_NAME=PHPFrame
MAIL_SECURE=tls
MAIL_CHARSET=UTF-8